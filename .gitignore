# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Secrets and local config
.env
.env.*
!.env.example

# Data — keep raw payload out of git (re-download via scripts)
data/*.json
!data/.gitkeep

# External third-party clones (GAAMA, HippoRAG2, etc.)
external/*/
!external/.gitkeep

# Results — generated, not source of truth
results/**/*.json
results/**/*.jsonl
results/**/*.csv
results/**/*.parquet
!results/**/.gitkeep

# Ablation artifacts
ablation/**/*.json
ablation/**/*.jsonl
!ablation/**/.gitkeep

# Logs / scratch
*.log
.scratch/

# OMC plugin session state (per-session; not project content)
.omc/

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store
