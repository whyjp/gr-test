# Copy to .env and fill in values. Do NOT commit .env.
# Used by optional-dependency [llm] features.

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Models (per plan)
EXTRACT_MODEL=gpt-4o-mini
ANSWER_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

# Retrieval budget (words)
RETRIEVAL_BUDGET_WORDS=1000

# Eval loop
N_RUNS=10
QA_CATEGORIES=1,2,3,4
